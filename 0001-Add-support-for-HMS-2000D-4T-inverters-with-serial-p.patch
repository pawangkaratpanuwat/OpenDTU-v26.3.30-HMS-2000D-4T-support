From 803ce4f86bce43c539cfc9543499f97e6e104b70 Mon Sep 17 00:00:00 2001
From: Your Name <you@example.com>
Date: Sun, 21 Jun 2026 22:33:27 +0700
Subject: [PATCH] Add support for HMS-2000D-4T inverters with serial prefix
 0x1421

The HMS-2000D-4T ships with serial numbers beginning 0x1421 (e.g.
1421A0208266), which is a 4-channel HMS inverter using the CMT2300A
radio but was not recognised by HMS_4CH::isValidSerial(). As a result
OpenDTU created no inverter object, never polled it, and reported the
type as "Unknown". Adding the 0x1421 prefix lets it be detected and
communicate normally.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 lib/Hoymiles/src/inverters/HMS_4CH.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/lib/Hoymiles/src/inverters/HMS_4CH.cpp b/lib/Hoymiles/src/inverters/HMS_4CH.cpp
index 8074593..1c12838 100644
--- a/lib/Hoymiles/src/inverters/HMS_4CH.cpp
+++ b/lib/Hoymiles/src/inverters/HMS_4CH.cpp
@@ -58,7 +58,7 @@ bool HMS_4CH::isValidSerial(const uint64_t serial)
 {
     // serial >= 0x116400000000 && serial <= 0x1164ffffffff
     uint16_t preSerial = (serial >> 32) & 0xffff;
-    return preSerial == 0x1164 || preSerial == 0x1166 || preSerial == 0x1420;
+    return preSerial == 0x1164 || preSerial == 0x1166 || preSerial == 0x1420 || preSerial == 0x1421;
 }
 
 String HMS_4CH::typeName() const
